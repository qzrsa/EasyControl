<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@android:color/transparent">

    <!-- 标题 -->
    <TextView
        android:id="@+id/text_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="连接模式"
        android:textSize="16sp"
        android:textStyle="bold" />

    <!-- 说明 -->
    <TextView
        android:id="@+id/text_detail"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="选择设备连接方式"
        android:textSize="12sp"
        android:textColor="#888888" />

    <!-- 连接模式选择 -->
    <RadioGroup
        android:id="@+id/radio_group_connect_mode"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="vertical" />

    <!-- 中继设置区域（仅P2P和中转模式显示） -->
    <LinearLayout
        android:id="@+id/layout_relay_settings"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="vertical"
        android:visibility="gone"
        android:padding="12dp"
        android:background="#1A000000">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="中继服务器设置"
            android:textSize="14sp"
            android:textStyle="bold" />

        <!-- 中继服务器地址 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="服务器地址"
            android:textSize="12sp" />
        <EditText
            android:id="@+id/input_relay_server"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="例如: relay.example.com"
            android:inputType="textUri"
            android:textSize="14sp" />

        <!-- 中继服务器端口 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="服务器端口"
            android:textSize="12sp" />
        <EditText
            android:id="@+id/input_relay_port"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="默认: 25167"
            android:inputType="number"
            android:textSize="14sp" />

        <!-- 连接令牌 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="连接令牌（设备标识）"
            android:textSize="12sp" />
        <EditText
            android:id="@+id/input_relay_token"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="用于P2P/中转连接"
            android:inputType="text"
            android:textSize="14sp" />
    </LinearLayout>

</LinearLayout>
