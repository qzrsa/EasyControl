<?xml version="1.0" encoding="utf-8"?>

<com.daitj.easycontrolfork.app.client.view.MyViewForSmallView xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:tools="http://schemas.android.com/tools"
  android:layout_width="wrap_content"
  android:layout_height="wrap_content">

  <EditText
    android:id="@+id/edit_text"
    android:layout_width="10dp"
    android:layout_height="10dp"
    android:layout_marginStart="20dp"
    android:layout_marginTop="50dp"
    android:inputType="textVisiblePassword" />

  <!--
    body 使用 FrameLayout，这样 texture_view_layout 和 nav_bar 可以叠放
    nav_bar 用 layout_gravity=bottom 直接钉在视频画面底部内部
    body 宽度跟随 texture_view_layout（视频实际宽度）
  -->
  <FrameLayout
    android:id="@+id/body"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_gravity="top|center_horizontal"
    android:layout_margin="6dp"
    android:background="@drawable/background_cron"
    android:elevation="4dp">

    <FrameLayout
      android:id="@+id/texture_view_layout"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content" />

    <!-- 导航栏叠在视频底部，背景透明，图标白色小字号 -->
    <LinearLayout
      android:id="@+id/nav_bar"
      android:layout_width="match_parent"
      android:layout_height="22dp"
      android:layout_gravity="bottom"
      android:orientation="horizontal"
      android:paddingStart="20dp"
      android:paddingEnd="20dp"
      android:background="@android:color/transparent"
      tools:ignore="RtlSymmetry">

      <ImageView
        android:id="@+id/button_back"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:focusable="false"
        android:padding="4dp"
        android:src="@drawable/caret_left"
        android:tint="#CCFFFFFF" />

      <ImageView
        android:id="@+id/button_home"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:focusable="false"
        android:padding="4dp"
        android:src="@drawable/o"
        android:tint="#CCFFFFFF" />

      <ImageView
        android:id="@+id/button_switch"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:focusable="false"
        android:padding="4dp"
        android:src="@drawable/square"
        android:tint="#CCFFFFFF" />

    </LinearLayout>
  </FrameLayout>

  <FrameLayout
    android:id="@+id/bar"
    android:layout_width="84dp"
    android:layout_height="22dp"
    android:layout_gravity="top|center_horizontal"
    android:elevation="5dp">

    <View
      android:layout_width="40dp"
      android:layout_height="4dp"
      android:layout_gravity="center_horizontal|bottom"
      android:layout_marginBottom="6dp"
      android:background="@drawable/background_cron"
      android:backgroundTint="#66FFFFFF"
      android:focusable="false" />
  </FrameLayout>

  <LinearLayout
    android:id="@+id/bar_view"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_gravity="top|center_horizontal"
    android:layout_marginTop="26dp"
    android:background="@drawable/background_cron"
    android:backgroundTint="#CCFFFFFF"
    android:elevation="5dp"
    android:orientation="vertical"
    android:padding="3dp">

    <LinearLayout
      android:layout_width="84dp"
      android:layout_height="26dp"
      android:orientation="horizontal">

      <ImageView
        android:id="@+id/button_app"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:background="@android:color/transparent"
        android:focusable="false"
        android:padding="4dp"
        android:src="@drawable/share"
        android:tint="@color/onCardBackground" />

      <ImageView
        android:id="@+id/button_mini"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:background="@android:color/transparent"
        android:focusable="false"
        android:padding="4dp"
        android:src="@drawable/minus"
        android:tint="@color/onCardBackground" />

      <ImageView
        android:id="@+id/button_full"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:background="@android:color/transparent"
        android:focusable="false"
        android:padding="4dp"
        android:src="@drawable/expand"
        android:tint="@color/onCardBackground" />

      <ImageView
        android:id="@+id/button_close"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:background="@android:color/transparent"
        android:focusable="false"
        android:padding="4dp"
        android:src="@drawable/x"
        android:tint="@color/alert" />
    </LinearLayout>

    <LinearLayout
      android:layout_width="84dp"
      android:layout_height="26dp"
      android:orientation="horizontal">

      <ImageView
        android:id="@+id/button_rotate"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:background="@android:color/transparent"
        android:focusable="false"
        android:padding="4dp"
        android:src="@drawable/horizontal_rotate"
        android:tint="@color/onCardBackground" />

      <ImageView
        android:id="@+id/button_nav_bar"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:background="@android:color/transparent"
        android:focusable="false"
        android:padding="4dp"
        android:src="@drawable/not_equal"
        android:tint="@color/onCardBackground" />

      <ImageView
        android:id="@+id/button_power"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:background="@android:color/transparent"
        android:focusable="false"
        android:padding="4dp"
        android:src="@drawable/power"
        android:tint="@color/onCardBackground" />

      <ImageView
        android:id="@+id/button_light"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:background="@android:color/transparent"
        android:focusable="false"
        android:padding="4dp"
        android:src="@drawable/lightbulb_off"
        android:tint="@color/onCardBackground" />
    </LinearLayout>

  </LinearLayout>

  <View
    android:id="@+id/re_size"
    android:layout_width="30dp"
    android:layout_height="40dp"
    android:layout_gravity="end|bottom"
    android:focusable="false" />

</com.daitj.easycontrolfork.app.client.view.MyViewForSmallView>
